{% extends 'base.html.twig' %}

{% block title %}Employés - Game Test{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Gestion des employés</h1>
            <p class="text-muted-foreground mt-2">Gérez votre équipe et leurs formations</p>
        </div>
        <a href="{{ path('app_dashboard') }}" class="text-sm text-muted-foreground hover:text-primary">
            ← Retour au dashboard
        </a>
    </div>

    {% for message in app.flashes('error') %}
        <div class="mb-4 p-4 rounded-md bg-destructive/10 text-destructive border border-destructive/20">
            {{ message }}
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 rounded-md bg-green-100 text-green-800 border border-green-200">
            {{ message }}
        </div>
    {% endfor %}

    {# Formations actives #}
    {% if activeTrainings is not empty %}
    <div class="mb-6 rounded-lg border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h2 class="text-2xl font-semibold leading-none tracking-tight">Formations en cours</h2>
        </div>
        <div class="p-6 pt-0">
            <div class="space-y-4">
                {% for training in activeTrainings %}
                <div class="flex items-center justify-between p-4 border rounded-lg">
                    <div>
                        <p class="font-semibold">{{ training.employee.name }}</p>
                        <p class="text-sm text-muted-foreground">
                            Formation vers {{ training.targetStars }} étoiles
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-sm text-muted-foreground">
                            {{ training.daysRemaining }} jour(s) restant(s) / {{ training.daysTotal }}
                        </p>
                        <div class="w-32 bg-muted rounded-full h-2 mt-2">
                            <div class="bg-primary h-2 rounded-full" style="width: {{ ((training.daysTotal - training.daysRemaining) / training.daysTotal * 100)|round }}%"></div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {# Liste des employés #}
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm mb-6">
        <div class="flex flex-col space-y-1.5 p-6">
            <h2 class="text-2xl font-semibold leading-none tracking-tight">Liste des employés</h2>
        </div>
        <div class="p-6 pt-0">
            {% if employees is not empty %}
                <div class="relative w-full overflow-auto">
                    <table class="w-full caption-bottom text-sm">
                        <thead class="[&_tr]:border-b">
                            <tr class="border-b transition-colors hover:bg-muted/50">
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Nom</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Rôle</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Étoiles</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Statut</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Salaire/jour</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Multiplicateur</th>
                                <th class="h-12 px-4 text-left align-middle font-medium text-muted-foreground">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-0">
                            {% for employee in employees %}
                            <tr class="border-b transition-colors hover:bg-muted/50">
                                <td class="p-4 align-middle font-medium">{{ employee.name }}</td>
                                <td class="p-4 align-middle">{{ employee.role }}</td>
                                <td class="p-4 align-middle">
                                    <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold">
                                        {% for i in 1..5 %}
                                            {% if i <= employee.trainingStars %}
                                                ⭐
                                            {% else %}
                                                ☆
                                            {% endif %}
                                        {% endfor %}
                                    </span>
                                </td>
                                <td class="p-4 align-middle">
                                    {% if employee.availabilityStatus == 'DISPO' %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 border-green-200">Disponible</span>
                                    {% elseif employee.availabilityStatus == 'FORMATION' %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-blue-100 text-blue-800 border-blue-200">En formation</span>
                                    {% elseif employee.availabilityStatus == 'SUR_POSTE' %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-yellow-100 text-yellow-800 border-yellow-200">Sur poste</span>
                                    {% else %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-gray-100 text-gray-800 border-gray-200">Arrêt</span>
                                    {% endif %}
                                </td>
                                <td class="p-4 align-middle">{{ employee.salaryDaily|number_format(2, ',', ' ') }} €</td>
                                <td class="p-4 align-middle">{{ employee.skillMultiplier }}x</td>
                                <td class="p-4 align-middle">
                                    {% if employee.isAvailable %}
                                        <button
                                            onclick="showTrainingModal({{ employee.id }}, '{{ employee.name }}', {{ employee.trainingStars }})"
                                            class="text-sm text-primary hover:underline"
                                        >
                                            Former
                                        </button>
                                    {% else %}
                                        <span class="text-sm text-muted-foreground">-</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-sm text-muted-foreground">Aucun employé pour le moment.</p>
            {% endif %}
        </div>
    </div>

    {# Encart informatif #}
    <div class="rounded-lg border bg-blue-50 border-blue-200 shadow-sm mb-6">
        <div class="flex flex-col space-y-1.5 p-6">
            <h2 class="text-xl font-semibold leading-none tracking-tight text-blue-900">ℹ️ Guide des rôles et progression</h2>
        </div>
        <div class="p-6 pt-0">
            <div class="space-y-4">
                <div>
                    <p class="text-sm font-medium text-blue-900 mb-2">Rôles et étapes du pipeline :</p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-sm">
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">🎨 DESIGNER</p>
                            <p class="text-blue-700">→ Étape DESIGN</p>
                        </div>
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">🖼️ GRAPHISTE</p>
                            <p class="text-blue-700">→ Étape GRAPHISM</p>
                        </div>
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">🔧 INTEGRATEUR</p>
                            <p class="text-blue-700">→ Étape INTEGRATION</p>
                        </div>
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">💻 DEV</p>
                            <p class="text-blue-700">→ Étape DEV</p>
                        </div>
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">👔 MANAGER</p>
                            <p class="text-blue-700">→ Toutes les étapes</p>
                        </div>
                        <div class="bg-white rounded p-3">
                            <p class="font-semibold text-blue-900">📋 RH</p>
                            <p class="text-blue-700">→ Gestion des formations</p>
                        </div>
                    </div>
                </div>
                <div class="bg-white rounded p-3">
                    <p class="text-sm font-medium text-blue-900 mb-2">⚡ Impact de plusieurs employés :</p>
                    <div class="space-y-2 text-sm text-blue-700">
                        <p>• <strong>1 employé</strong> (1 étoile) = <strong>10 points/jour</strong> → étape terminée en <strong>10 jours</strong></p>
                        <p>• <strong>2 employés</strong> (1 étoile chacun) = <strong>20 points/jour</strong> → étape terminée en <strong>5 jours</strong> (2x plus vite)</p>
                        <p>• <strong>3 employés</strong> (1 étoile chacun) = <strong>30 points/jour</strong> → étape terminée en <strong>3.3 jours</strong> (3x plus vite)</p>
                        <p class="mt-2 text-xs text-blue-600">💡 Plus d'employés = progression plus rapide ! Les gains s'additionnent.</p>
                    </div>
                </div>
                <div class="bg-white rounded p-3">
                    <p class="text-sm font-medium text-blue-900 mb-2">⭐ Impact des formations (multiplicateur) :</p>
                    <div class="space-y-1 text-sm text-blue-700">
                        <p>• 1 étoile = 1.00x (10 pts/jour)</p>
                        <p>• 2 étoiles = 1.35x (13.5 pts/jour)</p>
                        <p>• 3 étoiles = 1.70x (17 pts/jour)</p>
                        <p>• 4 étoiles = 2.05x (20.5 pts/jour)</p>
                        <p>• 5 étoiles = 2.40x (24 pts/jour)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Formulaire création employé #}
    <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
        <div class="flex flex-col space-y-1.5 p-6">
            <h2 class="text-2xl font-semibold leading-none tracking-tight">Recruter un employé</h2>
        </div>
        <div class="p-6 pt-0">
            <form method="POST" action="{{ path('app_employees_create') }}" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="role" class="block text-sm font-medium mb-2">Rôle</label>
                        <select
                            id="role"
                            name="role"
                            required
                            class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"
                        >
                            <option value="DEV">Développeur (120€/jour)</option>
                            <option value="DESIGNER">Designer (110€/jour)</option>
                            <option value="GRAPHISTE">Graphiste (100€/jour)</option>
                            <option value="INTEGRATEUR">Intégrateur (105€/jour)</option>
                            <option value="RH">RH (90€/jour)</option>
                            <option value="MANAGER">Manager (150€/jour)</option>
                        </select>
                        <p class="text-xs text-muted-foreground mt-1">Le nom et le salaire seront générés automatiquement</p>
                    </div>
                    <div>
                        <label for="count" class="block text-sm font-medium mb-2">Nombre d'employés à recruter</label>
                        <select
                            id="count"
                            name="count"
                            required
                            class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"
                        >
                            {% for i in 1..10 %}
                                <option value="{{ i }}" {% if i == 1 %}selected{% endif %}>{{ i }} employé{{ i > 1 ? 's' : '' }}</option>
                            {% endfor %}
                        </select>
                        <p class="text-xs text-muted-foreground mt-1">Recrutez plusieurs employés du même rôle en une fois</p>
                    </div>
                </div>
                <button
                    type="submit"
                    class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2"
                >
                    Recruter
                </button>
            </form>
        </div>
    </div>
</div>

{# Modal formation #}
<div id="training-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-card rounded-lg border shadow-lg p-6 max-w-md w-full mx-4">
        <h3 class="text-xl font-semibold mb-4">Démarrer une formation</h3>
        <form method="POST" action="" id="training-form" class="space-y-4">
            <input type="hidden" name="employeeId" id="training-employee-id" />
            <div>
                <label class="block text-sm font-medium mb-2">Employé</label>
                <p class="text-sm text-muted-foreground" id="training-employee-name"></p>
            </div>
            <div>
                <label for="targetStars" class="block text-sm font-medium mb-2">Étoiles actuelles</label>
                <p class="text-sm text-muted-foreground" id="training-current-stars"></p>
            </div>
            <div>
                <label for="targetStars" class="block text-sm font-medium mb-2">Étoiles cibles</label>
                <select
                    id="targetStars"
                    name="targetStars"
                    required
                    class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"
                >
                    <option value="2">2 étoiles</option>
                    <option value="3">3 étoiles</option>
                    <option value="4">4 étoiles</option>
                    <option value="5">5 étoiles</option>
                </select>
            </div>
            <div>
                <label for="daysTotal" class="block text-sm font-medium mb-2">Durée (jours)</label>
                <input
                    type="number"
                    id="daysTotal"
                    name="daysTotal"
                    min="1"
                    value="5"
                    required
                    class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"
                />
            </div>
            <div>
                <label for="cost" class="block text-sm font-medium mb-2">Coût (€)</label>
                <input
                    type="number"
                    id="cost"
                    name="cost"
                    step="0.01"
                    min="0"
                    value="500.00"
                    required
                    class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm"
                />
            </div>
            <div class="flex gap-4">
                <button
                    type="button"
                    onclick="hideTrainingModal()"
                    class="flex-1 inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2"
                >
                    Annuler
                </button>
                <button
                    type="submit"
                    class="flex-1 inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2"
                >
                    Démarrer
                </button>
            </div>
        </form>
    </div>
</div>

<script>
function showTrainingModal(employeeId, employeeName, currentStars) {
    document.getElementById('training-employee-id').value = employeeId;
    document.getElementById('training-employee-name').textContent = employeeName;
    document.getElementById('training-current-stars').textContent = currentStars + ' étoiles';
    document.getElementById('training-form').action = '/employees/' + employeeId + '/training/start';
    document.getElementById('training-modal').classList.remove('hidden');
}

function hideTrainingModal() {
    document.getElementById('training-modal').classList.add('hidden');
}

// Fermer le modal en cliquant en dehors
document.getElementById('training-modal').addEventListener('click', function(e) {
    if (e.target === this) {
        hideTrainingModal();
    }
});
</script>
{% endblock %}
