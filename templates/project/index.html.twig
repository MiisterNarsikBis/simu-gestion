{% extends 'base.html.twig' %}

{% block title %}Projets - Game Test{% endblock %}

{% block body %}
<div class="container mx-auto px-4 py-8">
    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Gestion des projets</h1>
            <p class="text-muted-foreground mt-2">Suivez vos projets et leur progression</p>
        </div>
        <div class="flex gap-4">
            <form method="POST" action="{{ path('app_projects_generate') }}">
                <button
                    type="submit"
                    class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2"
                >
                    Générer un nouveau projet
                </button>
            </form>
            <a href="{{ path('app_dashboard') }}" class="text-sm text-muted-foreground hover:text-primary">
                ← Retour au dashboard
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="mb-4 p-4 rounded-md bg-green-100 text-green-800 border border-green-200">
            {{ message }}
        </div>
    {% endfor %}

    {% if projects is not empty %}
        <div class="grid gap-6">
            {% for project in projects %}
            <div class="rounded-lg border bg-card text-card-foreground shadow-sm">
                <div class="flex flex-col space-y-1.5 p-6">
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="text-xl font-semibold leading-none tracking-tight">
                                {{ project.client.name }} - {{ project.type }}
                            </h3>
                            <p class="text-sm text-muted-foreground mt-1">
                                Budget : {{ project.budget|number_format(2, ',', ' ') }} €
                            </p>
                        </div>
                        <div class="text-right">
                            {% if project.status == 'NEW' %}
                                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-gray-100 text-gray-800 border-gray-200">Nouveau</span>
                            {% elseif project.status == 'IN_PROGRESS' %}
                                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-blue-100 text-blue-800 border-blue-200">En cours</span>
                            {% elseif project.status == 'DONE' %}
                                <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 border-green-200">Terminé</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <div class="p-6 pt-0">
                    <div class="space-y-4">
                        {# Pipeline stages #}
                        <div>
                            <p class="text-sm font-medium mb-2">Étape actuelle : {{ project.pipelineStage }}</p>
                            <div class="flex gap-2 flex-wrap">
                                {% set stages = ['BRIEF', 'WIREFRAME', 'DESIGN', 'GRAPHISM', 'INTEGRATION', 'DEV', 'QA', 'DELIVERY'] %}
                                {% set currentStageIndex = 0 %}
                                {% for stage in stages %}
                                    {% if stage == project.pipelineStage %}
                                        {% set currentStageIndex = loop.index0 %}
                                    {% endif %}
                                {% endfor %}
                                {% for stage in stages %}
                                    {% set stageIndex = loop.index0 %}
                                    {% if stage == project.pipelineStage %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-primary text-primary-foreground">
                                            {{ stage }}
                                        </span>
                                    {% elseif stageIndex < currentStageIndex %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-green-100 text-green-800 border-green-200">
                                            ✓ {{ stage }}
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold bg-muted text-muted-foreground">
                                            {{ stage }}
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </div>
                        </div>

                        {# Progression #}
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="text-muted-foreground">Progression de l'étape</span>
                                <span class="font-semibold">{{ project.stageProgress }}%</span>
                            </div>
                            <div class="w-full bg-muted rounded-full h-2">
                                <div class="bg-primary h-2 rounded-full" style="width: {{ project.stageProgress }}%"></div>
                            </div>
                        </div>

                        {# Qualité #}
                        <div class="flex items-center justify-between">
                            <span class="text-sm text-muted-foreground">Qualité</span>
                            <span class="text-sm font-semibold">{{ project.quality }}/100</span>
                        </div>

                        {# Employés assignés #}
                        {% set currentAssignments = assignmentsByProject[project.id] ?? [] %}
                        <div class="mt-4 pt-4 border-t">
                            <p class="text-sm font-medium mb-2">Employés assignés à cette étape</p>
                            {% if currentAssignments is not empty %}
                                <div class="space-y-2">
                                    {% for assignment in currentAssignments %}
                                        <div class="flex items-center justify-between bg-muted rounded p-2">
                                            <div>
                                                <p class="text-sm font-medium">{{ assignment.employee.name }}</p>
                                                <p class="text-xs text-muted-foreground">{{ assignment.employee.role }} - {{ assignment.employee.trainingStars }}⭐</p>
                                            </div>
                                            <form method="POST" action="{{ path('app_projects_unassign', {id: project.id, employeeId: assignment.employee.id}) }}" class="inline">
                                                <button type="submit" class="text-xs text-red-600 hover:text-red-800">Retirer</button>
                                            </form>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-xs text-muted-foreground">Aucun employé assigné (auto-assignment en cours)</p>
                            {% endif %}
                            
                            {# Formulaire pour assigner un employé #}
                            {% set requiredRole = project.requiredRole %}
                            {% if requiredRole %}
                                <form method="POST" action="{{ path('app_projects_assign', {id: project.id}) }}" class="mt-3">
                                    <div class="flex gap-2">
                                        <select name="employee_id" required class="flex-1 rounded-md border border-input bg-background px-3 py-2 text-sm">
                                            <option value="">Sélectionner un employé ({{ requiredRole }})</option>
                                            {% for employee in employees %}
                                                {% if employee.role == requiredRole and not employee.isInTraining %}
                                                    {% set isAssigned = false %}
                                                    {% for assignment in currentAssignments %}
                                                        {% if assignment.employee.id == employee.id %}
                                                            {% set isAssigned = true %}
                                                        {% endif %}
                                                    {% endfor %}
                                                    {% if not isAssigned %}
                                                        <option value="{{ employee.id }}">{{ employee.name }} ({{ employee.trainingStars }}⭐)</option>
                                                    {% endif %}
                                                {% endif %}
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2">
                                            Assigner
                                        </button>
                                    </div>
                                </form>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="rounded-lg border bg-card text-card-foreground shadow-sm p-6 text-center">
            <p class="text-muted-foreground">Aucun projet en cours. Générez un nouveau projet pour commencer !</p>
        </div>
    {% endif %}
</div>
{% endblock %}
